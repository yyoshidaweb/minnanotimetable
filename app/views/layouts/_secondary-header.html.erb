<%# セカンドヘッダー共通テンプレート %>
<% if defined?(@page_title) && @page_title.present? %>
  <header class="fixed left-0 w-full h-8 bg-white border-b border-gray-100 z-50 flex items-center
                  <%= secondary_header_top_position %>">
    <div class="w-full mx-auto px-4 sm:px-6 lg:px-8 flex justify-center items-center">
      <h1 class="text-sm text-gray-800"><%= @page_title %></h1>
    </div>
  </header>
<% end %>