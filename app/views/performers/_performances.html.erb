<div class="mb-4">
  <% if performances.empty? %>
    <p class="text-gray-500 border-b py-4">出演情報がありません</p>
  <% else %>
    <% performances.each do |performance| %>
      <div class="flex justify-between items-center border-b py-2">
        <div class="text-sm text-gray-500">
          <p>
            <% if performance.day.present? %>
              <%= performance.day.date.strftime("%-Y/%-m/%-d") %>
            <% else %>
              出演日：未定
            <% end %>
            <% if performance.start_time.present? && performance.end_time.present? %>
              <%= "#{performance.start_time.strftime("%H:%M")}~#{performance.end_time.strftime("%H:%M")}" %>
            <% else %>
              時刻：未定
            <% end %>
          </p>
          <p>
            <% if performance.stage.present? %>
              <%= link_to event_stage_path(@event.event_key, performance.stage),
                        class: "flex items-center text-blue-600" do %>
                <span class="line-clamp-1"><%= performance.stage.display_name %></span>
                <span class="material-symbols-outlined" style="font-size: 1.2rem;">moved_location</span>
              <% end %>
            <% else %>
              ステージ：未定
            <% end %>
          </p>
        </div>
        <%# お気に入りボタンと編集ボタン %>
        <div class="flex items-center">
          <% if user_signed_in? %>
            <%# 編集ボタン（出演者の作成者のみ表示） %>
            <% if current_user == @event.user %>
              <%= link_to edit_event_performance_path(@event.event_key, performance),
                              class: "mx-4 flex items-center text-sm text-gray-800" do %>
                <span class="material-symbols-outlined">edit_calendar</span>
              <% end %>
            <% end %>
            <%# お気に入りボタン %>
            <%# performance_favoriteのidを取得 %>
            <% favorite_id = @favorite_performance_map[performance.id] %>
            <% if favorite_id %>
              <%# お気に入り済みの場合 %>
              <%= button_to performance_favorite_path(favorite_id),
                                          method: :delete,
                                          class: "flex items-center" do %>
                <span class="material-symbols-outlined material-symbols-filled text-orange-600 cursor-pointer">
                  favorite
                </span>
              <% end %>
            <% else %>
              <%# お気に入りではない場合 %>
              <%= button_to performance_favorites_path(performance_id: performance.id),
                                          method: :post,
                                          class: "flex items-center text-gray-800" do %>
                <span class="material-symbols-outlined cursor-pointer">
                  favorite
                </span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
<%# 出演情報作成ボタン %>
<% if user_signed_in? && current_user == @event.user %>
  <div class="flex justify-end items-center mb-4">
    <%= link_to new_event_performance_path(@event.event_key, performer_id: @performer.id),
                    class: "flex items-center justify-center px-2.5 py-1.5 bg-gray-800 text-white rounded-full shadow hover:bg-gray-900" do %>
      <span class="material-symbols-outlined mr-1"
                    style="font-size: 1.35rem">calendar_add_on</span>
      <span class="text-xs">出演情報を追加</span>
    <% end %>
  </div>
<% end %>